# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Admin Token for backend API authentication (x-admin-token header)
ADMIN_TOKEN=your_secret_admin_token_here

# Site URL - used for canonical links, sitemap, and robots.txt
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App URL - used for OAuth redirects and internal navigation logic
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Optional - configured in Supabase Dashboard under Authentication > Providers > Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
